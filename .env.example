# Anthropic Claude API (server-side only — never use NEXT_PUBLIC_ prefix)
ANTHROPIC_API_KEY=your_api_key_here

# Soft access gate — comma-separated list of accepted passwords (e.g. "alice,bob,demo").
# Leave blank to disable the gate. Note: NEXT_PUBLIC_ vars are bundled into the client,
# so this is a casual gate, not a security boundary.
NEXT_PUBLIC_ACCESS_PASSWORD=
